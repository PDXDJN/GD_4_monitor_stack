# Normalize line endings for all text files
* text=auto

# Godot source files — LF
*.gd        text eol=lf
*.gdshader  text eol=lf
*.tscn      text eol=lf
*.tres      text eol=lf
*.godot     text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.svg       text eol=lf

# Binary assets — no line-ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.wav       binary
*.ogg       binary
*.mp3       binary
*.ttf       binary
*.otf       binary
